# =====================================================================
#  Produktions-.env für DomainFactory (Ordner: Projekte/wkr4)
#  Vorgehen:
#    1) Diese Datei auf dem Server nach ".env" kopieren
#    2) DB_PASSWORD + MAIL_* + APP_URL ausfüllen
#    3) einmalig: php artisan key:generate   (setzt APP_KEY)
#  .env NIEMALS committen (steht in .gitignore).
# =====================================================================

APP_NAME="Wunschkennzeichen-Portal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.wunschkennzeichen-reservieren.de

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# In Produktion nur echte Fehler loggen
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Datenbank (DomainFactory) -------------------------------------
DB_CONNECTION=mysql
DB_HOST=localhost          # bei DF i.d.R. localhost; sonst DB-Host aus dem DF-Kundenmenü
DB_PORT=3306
DB_DATABASE=db96617_82
DB_USERNAME=db96617_82
DB_PASSWORD=               # <-- im DF-Menü vergebenes DB-Passwort eintragen

# Kein Redis/Memcached auf DF-Shared -> alles über die Datenbank
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- E-Mail (DomainFactory SMTP) -----------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtprelaypool.ispgateway.de   # DF-SMTP – ggf. laut DF-Menü anpassen
MAIL_PORT=587
MAIL_SCHEME=null
MAIL_USERNAME=               # DF-Postfach-Adresse
MAIL_PASSWORD=               # DF-Postfach-Passwort
MAIL_FROM_ADDRESS="info@wunschkennzeichen-reservieren.de"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
